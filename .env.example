# ════════════════════════════════════════════════════════════════════
# ASR Configuration — copy to .env and fill in values
# ════════════════════════════════════════════════════════════════════

# ── Neo4j ──────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_DATABASE=neo4j
NEO4J_PASSWORD=changeme

# ── Authentication (Entra ID) ─────────────────────────────────────
# Register an app in Azure Portal > App registrations
# Set redirect URI to your frontend URL
ENTRA_TENANTID=              # Azure AD tenant GUID
ENTRA_CLIENTID=              # App registration client ID
ENTRA_ALLOWEDTENANTS=        # Comma-separated tenant GUIDs (empty = all)

# ── Server ────────────────────────────────────────────────────────
SERVER_CORSALLOWEDORIGINS=   # Comma-separated origins (empty = allow all in dev)
PORT=3100                    # API listen port

# ── STORM Scoring (optional) ─────────────────────────────────────
# Leave empty/false to use local RSK scoring engine
STORM_ENABLED=false
STORM_BASE_URL=
KEYCLOAK_BASE_URL=
KEYCLOAK_REALM=
KEYCLOAK_CLIENT_ID=
KEYCLOAK_CLIENT_SECRET=

# ── Infisical (optional — leave disabled for .env-based config) ──
# For RESCOR internal deployments that use Infisical for secret management.
# Third-party deployments can ignore this section entirely.
INFISICAL_ENABLED=false
INFISICAL_HOST=
INFISICAL_CLIENT_ID=
INFISICAL_CLIENT_SECRET=
INFISICAL_PROJECT_ID=
INFISICAL_ENVIRONMENT=

# ── Seed Data (used by cypher:setup) ─────────────────────────────
SEED_TENANT_ID=default
SEED_TENANT_NAME=My Organization
SEED_TENANT_DOMAIN=example.com
SEED_ADMIN_EMAIL=admin@example.com

# ── Frontend Build Vars (set before building frontend) ───────────
VITE_MSAL_CLIENT_ID=         # Same as ENTRA_CLIENTID
VITE_MSAL_TENANT_ID=         # Same as ENTRA_TENANTID (optional, defaults to 'common')
VITE_MSAL_REDIRECT_URI=      # Default: window.location.origin
